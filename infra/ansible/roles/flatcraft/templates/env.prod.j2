# {{ ansible_managed }}
# DO NOT EDIT MANUALLY — генерується з infra/ansible/roles/flatcraft/templates/env.prod.j2
# При зміні: edit template + ansible-playbook --tags deploy.

# ─── Image / version ────────────────────────────────────────────────────────
IMAGE_PREFIX={{ image_prefix }}
APP_VERSION={{ app_version }}

# ─── Загальне ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL={{ log_level }}

# ─── Public URLs ────────────────────────────────────────────────────────────
APP_BASE_URL={{ app_base_url }}
API_BASE_URL={{ api_base_url }}
NEXT_PUBLIC_API_BASE_URL={{ api_base_url }}

# Inter-service URL'и (docker internal DNS)
INTERNAL_API_URL=http://api:4000
CAD_WORKER_URL=http://cad-worker:8080

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_DB={{ postgres_db }}
DATABASE_URL=postgresql://{{ postgres_user }}:{{ vault_postgres_password }}@postgres:5432/{{ postgres_db }}

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Cloudflare R2 ──────────────────────────────────────────────────────────
S3_ENDPOINT={{ vault_s3_endpoint }}
S3_REGION=auto
S3_ACCESS_KEY_ID={{ vault_s3_access_key_id }}
S3_SECRET_ACCESS_KEY={{ vault_s3_secret_access_key }}
S3_BUCKET={{ s3_bucket }}
S3_BUCKET_BACKUPS={{ s3_bucket_backups }}
S3_FORCE_PATH_STYLE=true

# ─── Auth ───────────────────────────────────────────────────────────────────
AUTH_SECRET={{ vault_auth_secret }}
AUTH_TRUST_HOST=true
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ─── Sentry ─────────────────────────────────────────────────────────────────
SENTRY_DSN={{ vault_sentry_dsn | default('', true) }}
SENTRY_ENVIRONMENT={{ sentry_environment }}

# ─── Limits ─────────────────────────────────────────────────────────────────
FREE_EXPORTS_PER_MONTH=10
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_EXPORT_PER_MIN=5

# ─── CAD worker ─────────────────────────────────────────────────────────────
CAD_WORKER_CONCURRENCY=1
CAD_WORKER_TIMEOUT_SECONDS=60

# ─── Admin seed ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL={{ seed_admin_email }}
SEED_ADMIN_PASSWORD={{ vault_seed_admin_password }}
