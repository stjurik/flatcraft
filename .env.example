# Скопіюйте у .env і заповніть. Ніколи не комітьте .env у git.

# ─── Загальне ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=flatcraft
POSTGRES_PASSWORD=flatcraft_dev_only_change_me
POSTGRES_DB=flatcraft
DATABASE_URL=postgresql://flatcraft:flatcraft_dev_only_change_me@localhost:5432/flatcraft

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── S3 / R2 / MinIO ───────────────────────────────────────────────────────
# У dev — MinIO у docker-compose (значення нижче).
# У prod — Cloudflare R2 ОБОВ'ЯЗКОВО (сервер Mirohost Cloud MS21 має лише 40 ГБ
# диска, локально зберігати артефакти не можна; self-hosted MinIO у prod не
# використовуємо — див. ADR-008, ADR-011).
# Для R2: S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com, S3_REGION=auto
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=flatcraft-artifacts
S3_BUCKET_BACKUPS=flatcraft-backups
S3_REGION=auto
S3_FORCE_PATH_STYLE=true

# ─── Auth ──────────────────────────────────────────────────────────────────
AUTH_SECRET=replace_with_long_random_string_min_32_chars
AUTH_TRUST_HOST=true
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Google OAuth (https://console.cloud.google.com)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Email (для верифікації + сповіщень) ───────────────────────────────────
# Postmark або Resend; у dev — Mailpit у docker-compose
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="flatcraft <noreply@flatcraft.local>"

# ─── Sentry ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ─── Plausible ─────────────────────────────────────────────────────────────
PLAUSIBLE_DOMAIN=
PLAUSIBLE_API_HOST=

# ─── Donations ─────────────────────────────────────────────────────────────
DONATION_MONOBANK_BANKA_URL=https://send.monobank.ua/jar/...
DONATION_UNITED24_URL=https://u24.gov.ua/
DONATION_USDT_TRC20_ADDRESS=
DONATION_USDT_ERC20_ADDRESS=
DONATION_MIN_AMOUNT_UAH=200
DONATION_BONUS_DAYS=30

# ─── Limits ────────────────────────────────────────────────────────────────
FREE_EXPORTS_PER_MONTH=10
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_EXPORT_PER_MIN=5

# ─── CAD Worker ────────────────────────────────────────────────────────────
CAD_WORKER_CONCURRENCY=2
CAD_WORKER_TIMEOUT_SECONDS=60

# ─── Адмін ─────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@flatcraft.local
SEED_ADMIN_PASSWORD=change_me_after_first_login_min_12_chars
