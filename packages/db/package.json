{
  "name": "@flatcraft/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "studio": "drizzle-kit studio",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@flatcraft/types": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1",
    "vitest": "^2.1.2"
  }
}
