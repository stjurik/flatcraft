{
  "name": "@flatcraft/cad-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./node": "./dist/spec-node.js",
    "./data/bend-machine-esi.yaml": "./data/bend-machine-esi.yaml"
  },
  "scripts": {
    "bake": "tsx ../../tools/scripts/bake-bend-matrix.ts",
