# ════════════════════════════════════════════════════════════════════════════
#  flatcraft / staging — production-style env template
#  Скопіювати → `.env.prod` на сервері, заповнити значення. Секрети — НЕ комітимо.
#  Команда запуску:
#      docker compose --env-file .env.prod \
#        -f infra/compose/docker-compose.prod.yml up -d
#  Генерація випадкових секретів: openssl rand -hex 32
# ════════════════════════════════════════════════════════════════════════════

# ─── Image / version ────────────────────────────────────────────────────────
# При release переписати APP_VERSION на git-sha (auto з CI) або тег (v0.5.0).
IMAGE_PREFIX=ghcr.io/stjurik/flatcraft
APP_VERSION=staging

# ─── Загальне ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Publication URLs (бачить браузер) ──────────────────────────────────────
APP_BASE_URL=https://staging.hart.crimea.ua
API_BASE_URL=https://api.staging.hart.crimea.ua
NEXT_PUBLIC_API_BASE_URL=https://api.staging.hart.crimea.ua

# Inter-service URL'и всередині docker-мережі (НЕ змінювати без потреби).
INTERNAL_API_URL=http://api:4000
CAD_WORKER_URL=http://cad-worker:8080

# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=flatcraft
# openssl rand -hex 32
POSTGRES_PASSWORD=__REPLACE_postgres_password__
POSTGRES_DB=flatcraft
# DATABASE_URL використовує internal docker DNS `postgres`, НЕ localhost.
# Підставити те саме значення, що в POSTGRES_PASSWORD (без url-encoding для hex-рядка).
DATABASE_URL=postgresql://flatcraft:__REPLACE_postgres_password__@postgres:5432/flatcraft

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Cloudflare R2 (S3-compatible, ADR-008/ADR-011) ─────────────────────────
# R2 endpoint: https://<cf_account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=https://__REPLACE_cf_account_id__.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=__REPLACE_r2_token_access_key__
S3_SECRET_ACCESS_KEY=__REPLACE_r2_token_secret_key__
S3_BUCKET=flatcraft-artifacts
S3_BUCKET_BACKUPS=flatcraft-backups
S3_FORCE_PATH_STYLE=true

# ─── Auth (потрібен зараз, OAuth — у Phase 3) ───────────────────────────────
# openssl rand -hex 32
AUTH_SECRET=__REPLACE_auth_secret__
AUTH_TRUST_HOST=true
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ─── Sentry (заповнимо у Phase 5.1) ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

# ─── Limits ─────────────────────────────────────────────────────────────────
FREE_EXPORTS_PER_MONTH=10
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_EXPORT_PER_MIN=5

# ─── CAD worker ─────────────────────────────────────────────────────────────
# CONCURRENCY=1 ОБОВ'ЯЗКОВО на тарифі MS21 (4 GB RAM) — ADR-011.
CAD_WORKER_CONCURRENCY=1
CAD_WORKER_TIMEOUT_SECONDS=60

# ─── Admin seed (Phase 3) ───────────────────────────────────────────────────
# openssl rand -hex 16
SEED_ADMIN_EMAIL=admin@hart.crimea.ua
SEED_ADMIN_PASSWORD=__REPLACE_admin_password__

# ─── Placeholder'и для майбутніх фаз ─────────────────────────────────────────
# Можуть бути порожніми зараз — compose не падає на missing optional.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DONATION_MONOBANK_BANKA_URL=
DONATION_UNITED24_URL=
DONATION_USDT_TRC20_ADDRESS=
DONATION_USDT_ERC20_ADDRESS=
DONATION_MIN_AMOUNT_UAH=200
DONATION_BONUS_DAYS=30
PLAUSIBLE_DOMAIN=
PLAUSIBLE_API_HOST=
