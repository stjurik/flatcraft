{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      // Exact subpath ПЕРЕД wildcard (Hotfix 2.9.c): `@flatcraft/cad-engine/node`
      // інакше матчиться wildcard'ом у `packages/cad-engine/node/src` (не існує),
      // tsx/tsc падають у node-resolution → dist/spec-node.js (несобраний у dev).
      // Явний мапінг тримає browser-unsafe fs-loader резолвним із source.
      "@flatcraft/cad-engine/node": ["packages/cad-engine/src/spec-node.ts"],
      "@flatcraft/cad-engine/geometry": ["packages/cad-engine/src/geometry/index.ts"],
      "@flatcraft/*": ["packages/*/src", "apps/*/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "build", "coverage"]
}
