{
  "name": "@flatcraft/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:int": "vitest run --config vitest.int.config.ts",
    "openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@flatcraft/db": "workspace:*",
    "@flatcraft/types": "workspace:*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/csrf-protection": "^7.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.1.0",
    "@node-rs/argon2": "^2.0.0",
    "@sentry/node": "^8.34.0",
    "bullmq": "^5.20.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.1",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.12.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.1",
    "vitest": "^2.1.2"
  }
}
