# Dependencies
node_modules/
.pnpm-store/
.pnpm-debug.log
.venv/
venv/
__pycache__/
*.pyc

# Build outputs
.next/
.turbo/
dist/
build/
out/
*.tsbuildinfo
# Next.js auto-generates next-env.d.ts; не комітимо.
next-env.d.ts
# tsc/tsx leak: інколи incremental build emit'ить .js/.d.ts поряд з .ts у src/.
# Реальні артефакти збірки — у dist/. Виключаємо, але .ts/.tsx/.test.ts —
# нормальні файли.
packages/**/src/**/*.js
packages/**/src/**/*.d.ts
packages/**/src/**/*.js.map
packages/**/src/**/*.d.ts.map

# Coverage
coverage/
.nyc_output/
htmlcov/
.coverage
.coverage.*
.pytest_cache/

# Test artifacts
playwright-report/
test-results/
**/snapshots-actual/

# Env / secrets
.env
.env.local
.env.*.local
.env.prod
!.env.example
!.env.prod.example
*.pem
*.key
secrets/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Drizzle / DB
packages/db/drizzle/

# Python (uv)
uv.lock-tmp

# CAD artifacts (генеровані локально)
workers/cad/out/
*.dxf
!packages/cad-engine/data/*.dxf
!workers/cad/tests/snapshots/**/*.dxf
*.step
*.pdf
!docs/**/*.pdf
*.stl
*.iges

# Sentry
.sentryclirc

# Local infra (Ansible — Terraform не використовуємо, див. ADR-011)
infra/ansible/*.retry
infra/ansible/inventory.ini
# runtime-generated у deploy-staging.yml + може містити реальний origin IP
infra/ansible/inventory.staging.ini
infra/ansible/inventory.production.ini
# all.yml — non-secret config-as-code, committed: site.yml vars_files його вимагає
# у CI-чекауті (deploy-staging.yml). Секрети — лише в all.vault.yml (зашифровано).
!infra/ansible/inventory.ini.example
!infra/ansible/group_vars/all.yml.example
!infra/ansible/group_vars/all.vault.yml.example
# all.vault.yml — комітимо ЗАШИФРОВАНИМ (ansible-vault encrypt). pre-commit
# hook у lefthook.yml перевіряє `$ANSIBLE_VAULT` header перед прийняттям.

# Logs
*.log
logs/

# Docker
.docker/

# Cache
.cache/

# Claude Code локальні налаштування (permission allowlist з машинно-специфічними
# командами + session lock) — не для публічного репо.
.claude/settings.local.json
.claude/scheduled_tasks.lock
